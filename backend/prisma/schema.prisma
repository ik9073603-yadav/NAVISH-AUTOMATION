// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  OWNER
  MANAGER
  EMPLOYEE
}

enum AccountStatus {
  INVITED
  ACTIVE
  DEACTIVATED
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  industry  String?
  timezone  String   @default("Asia/Kolkata")
  gstin     String?
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Working-hours gate for the automation engine (Feature: no 2 AM pings).
  workingDays Int[]    @default([1, 2, 3, 4, 5, 6]) // ISO weekday: 1=Mon ... 7=Sun
  shiftStart  String   @default("09:00")
  shiftEnd    String   @default("18:00")
  holidays    String[] @default([])                  // "YYYY-MM-DD", org-local calendar date

  // Superadmin suspend switch — distinct from "active recently" usage metric.
  // Blocks new logins for this org when false; existing sessions expire naturally.
  enabled     Boolean  @default(true)

  users             User[]
  departments       Department[]
  activityLogs      ActivityLog[]
  resetRequests     ResetRequest[]
  deletionRequests  DeletionRequest[]
  tasks             Task[]
  notifications     Notification[]
  deviceTokens      DeviceToken[]
  checklistRules    ChecklistRule[]
  flows             Flow[]
  skus              Sku[]

  @@map("organizations")
}

model Department {
  id     String @id @default(uuid())
  orgId  String
  name   String

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  users        User[]

  @@unique([orgId, name])
  @@index([orgId])
  @@map("departments")
}

model User {
  id           String        @id @default(uuid())
  orgId        String
  name         String
  email        String
  phone        String?
  passwordHash String
  role         Role          @default(EMPLOYEE)
  status       AccountStatus @default(ACTIVE)
  managerId    String?
  departmentId String?
  photoUrl     String?
  language     String        @default("en")
  nickname     String?
  designation  String?

  // Cross-org platform capability, separate from org Role. Never settable via
  // any API — only ever flipped by a direct DB script. See scripts/set-superadmin.mjs.
  isSuperAdmin Boolean       @default(false)

  // Recorded at signup — the checkbox is mandatory, this is the audit trail.
  termsAcceptedAt DateTime?
  termsVersion    String?

  // Per-person inventory write permissions — OWNER/MANAGER are always allowed
  // regardless of these flags (checked in code, not stored here); these only
  // gate EMPLOYEE. Both default false: nobody can move stock until granted.
  canStockIn  Boolean @default(false)
  canStockOut Boolean @default(false)

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  department   Department?  @relation(fields: [departmentId], references: [id])
  manager      User?        @relation("ManagerChain", fields: [managerId], references: [id])
  reports      User[]       @relation("ManagerChain")

  @@unique([orgId, email])
  @@index([orgId])
  @@index([managerId])
  @@map("users")
}

model ActivityLog {
  id        String   @id @default(uuid())
  orgId     String
  actorId   String?
  action    String
  entity    String
  entityId  String?
  meta      Json?
  createdAt DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, createdAt])
  @@map("activity_logs")
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  STUCK
  DONE
  CANCELLED
}

enum TaskSource {
  DELEGATION
  CHECKLIST
  FMS_STAGE
  INVENTORY_ALERT
}

enum ResetRequestStatus {
  PENDING
  APPROVED
  DENIED
}

// Employee forgot password (logged out, can't use change-password) → asks
// their org's owner/manager to reset it for them. Distinct from change-password.
model ResetRequest {
  id           String              @id @default(uuid())
  orgId        String
  userId       String
  status       ResetRequestStatus  @default(PENDING)
  requestedAt  DateTime            @default(now())
  resolvedAt   DateTime?
  resolvedById String?

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, status])
  @@map("reset_requests")
}

enum DeletionRequestStatus {
  PENDING
  COMPLETED
  DENIED
}

// Feature 176 — consent + data-deletion. Files a request; the org owner (or
// superadmin) actions it manually. For now "completed" means the account is
// deactivated, not a hard data wipe — scaffolding, not a full erasure pipeline.
model DeletionRequest {
  id           String                 @id @default(uuid())
  orgId        String
  userId       String
  status       DeletionRequestStatus  @default(PENDING)
  requestedAt  DateTime               @default(now())
  resolvedAt   DateTime?
  resolvedById String?

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, status])
  @@map("deletion_requests")
}

model Task {
  id          String     @id @default(uuid())
  orgId       String
  title       String
  description String?
  source      TaskSource @default(DELEGATION)
  status      TaskStatus @default(PENDING)
  priority    String     @default("NORMAL")

  assigneeId  String
  createdById String

  dueAt        DateTime?
  completedAt  DateTime?
  stuckReason  String?

  ruleId       String?    // kis checklist rule se bana

  // The engine's brain:
  nextActionAt   DateTime?
  chaseCount     Int       @default(0)
  escalatedAt    DateTime?
  escalatedToId  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, status])
  @@index([nextActionAt])
  @@index([assigneeId, status])
  @@map("tasks")
}

model Notification {
  id        String   @id @default(uuid())
  orgId     String
  userId    String
  type      String
  title     String
  body      String
  taskId    String?
  readAt    DateTime?
  createdAt DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, userId, createdAt])
  @@map("notifications")
}

model DeviceToken {
  id        String   @id @default(uuid())
  orgId     String
  userId    String
  token     String   @unique
  platform  String                  // android / ios / web
  createdAt DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([orgId])
  @@map("device_tokens")
}

enum Recurrence {
  DAILY
  WEEKLY
  MONTHLY
}

model ChecklistRule {
  id          String     @id @default(uuid())
  orgId       String
  title       String
  description String?
  assigneeId  String
  createdById String

  recurrence  Recurrence
  timeOfDay   String     // "09:00" — us din kis waqt due hoga
  weekday     Int?       // WEEKLY ke liye: 1=Mon ... 7=Sun
  dayOfMonth  Int?       // MONTHLY ke liye: 1-28

  priority    String     @default("NORMAL")
  active      Boolean    @default(true)

  nextFireAt  DateTime?  // agli baar kab task banega
  lastFiredAt DateTime?

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, active])
  @@index([nextFireAt])
  @@map("checklist_rules")
}

enum FieldType {
  TEXT
  NUMBER
  DROPDOWN
  DATE
  PHOTO
  YESNO
}

enum OrderStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

model Flow {
  id          String   @id @default(uuid())
  orgId       String
  name        String
  prefix      String   @default("ORD")   // order number: ORD-001
  itemLabel   String   @default("Item")
  active      Boolean  @default(true)
  orderCount  Int      @default(0)
  createdAt   DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  stages StageDef[]
  orders Order[]

  @@index([orgId])
  @@map("flows")
}

model StageDef {
  id            String  @id @default(uuid())
  orgId         String
  flowId        String
  name          String
  sequence      Int                      // 1, 2, 3...
  responsibleId String?                  // kaun karega
  plannedMins   Int?                     // kitna time lagna chahiye

  flow   Flow       @relation(fields: [flowId], references: [id], onDelete: Cascade)
  fields FieldDef[]

  @@index([flowId, sequence])
  @@map("stage_defs")
}

model FieldDef {
  id       String    @id @default(uuid())
  orgId    String
  stageId  String
  label    String
  type     FieldType @default(TEXT)
  required Boolean   @default(false)
  options  String?                     // DROPDOWN ke liye: "A,B,C"
  sequence Int       @default(0)

  stage StageDef @relation(fields: [stageId], references: [id], onDelete: Cascade)

  @@index([stageId])
  @@map("field_defs")
}

model Order {
  id          String      @id @default(uuid())
  orgId       String
  flowId      String
  orderNumber String
  status      OrderStatus @default(ACTIVE)

  currentStageId String?
  startedAt      DateTime  @default(now())
  completedAt    DateTime?

  flow   Flow            @relation(fields: [flowId], references: [id], onDelete: Cascade)
  stages OrderStage[]

  @@unique([orgId, orderNumber])
  @@index([orgId, status])
  @@map("orders")
}

model OrderStage {
  id        String    @id @default(uuid())
  orgId     String
  orderId   String
  stageId   String
  sequence  Int

  taskId       String?     // engine ka task
  enteredAt    DateTime?   // kab yahan aaya
  completedAt  DateTime?
  completedById String?
  data         Json?       // custom fields ka data
  delayMins    Int?        // planned vs actual (actual − plannedDeadline, working-time aware)

  // The working-time deadline computed on entry: addWorkingTime(previous
  // stage's actual completion, this stage's plannedMins). Null when the
  // stage itself is unplanned (plannedMins == null on its StageDef) — no
  // deadline, no chasing, but completedAt still feeds the next stage's clock.
  plannedDeadline DateTime?

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orgId, orderId])
  @@index([stageId])
  @@map("order_stages")
}

model Sku {
  id            String   @id @default(uuid())
  orgId         String
  name          String
  code          String
  category      String?
  unit          String   @default("pcs")      // kg / pcs / box / litre — free text
  imageUrl      String?
  currentStock  Float    @default(0)
  minStock      Float?                        // null = no min alert
  maxStock      Float?                        // null = no max alert
  unitCost      Float?                        // for stock value in Rupees
  lastMovedAt   DateTime?                     // drives liquid-vs-dead classification
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  movements StockMovement[]

  @@unique([orgId, code])
  @@index([orgId, active])
  @@map("skus")
}

enum MovementType {
  IN
  OUT
  ADJUST
}

model StockMovement {
  id        String       @id @default(uuid())
  orgId     String
  skuId     String
  type      MovementType
  quantity  Float
  reason    String?                      // source (IN) / reason (OUT) / note (ADJUST)
  doneById  String
  balance   Float                        // running stock AFTER this movement
  createdAt DateTime     @default(now())

  sku Sku @relation(fields: [skuId], references: [id], onDelete: Cascade)

  @@index([orgId, skuId, createdAt])
  @@map("stock_movements")
}