// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  OWNER
  MANAGER
  EMPLOYEE
}

enum AccountStatus {
  INVITED
  ACTIVE
  DEACTIVATED
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  industry  String?
  timezone  String   @default("Asia/Kolkata")
  gstin     String?
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users       User[]
  departments Department[]

  @@map("organizations")
}

model Department {
  id     String @id @default(uuid())
  orgId  String
  name   String

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  users        User[]

  @@unique([orgId, name])
  @@index([orgId])
  @@map("departments")
}

model User {
  id           String        @id @default(uuid())
  orgId        String
  name         String
  email        String
  phone        String?
  passwordHash String
  role         Role          @default(EMPLOYEE)
  status       AccountStatus @default(ACTIVE)
  managerId    String?
  departmentId String?
  photoUrl     String?
  language     String        @default("en")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  department   Department?  @relation(fields: [departmentId], references: [id])
  manager      User?        @relation("ManagerChain", fields: [managerId], references: [id])
  reports      User[]       @relation("ManagerChain")

  @@unique([orgId, email])
  @@index([orgId])
  @@index([managerId])
  @@map("users")
}

model ActivityLog {
  id        String   @id @default(uuid())
  orgId     String
  actorId   String?
  action    String
  entity    String
  entityId  String?
  meta      Json?
  createdAt DateTime @default(now())

  @@index([orgId, createdAt])
  @@map("activity_logs")
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  STUCK
  DONE
  CANCELLED
}

enum TaskSource {
  DELEGATION
  CHECKLIST
  FMS_STAGE
  INVENTORY_ALERT
}

model Task {
  id          String     @id @default(uuid())
  orgId       String
  title       String
  description String?
  source      TaskSource @default(DELEGATION)
  status      TaskStatus @default(PENDING)
  priority    String     @default("NORMAL")

  assigneeId  String
  createdById String

  dueAt        DateTime?
  completedAt  DateTime?
  stuckReason  String?

  ruleId       String?    // kis checklist rule se bana

  // The engine's brain:
  nextActionAt   DateTime?
  chaseCount     Int       @default(0)
  escalatedAt    DateTime?
  escalatedToId  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, status])
  @@index([nextActionAt])
  @@index([assigneeId, status])
  @@map("tasks")
}

model Notification {
  id        String   @id @default(uuid())
  orgId     String
  userId    String
  type      String
  title     String
  body      String
  taskId    String?
  readAt    DateTime?
  createdAt DateTime @default(now())

  @@index([orgId, userId, createdAt])
  @@map("notifications")
}

enum Recurrence {
  DAILY
  WEEKLY
  MONTHLY
}

model ChecklistRule {
  id          String     @id @default(uuid())
  orgId       String
  title       String
  description String?
  assigneeId  String
  createdById String

  recurrence  Recurrence
  timeOfDay   String     // "09:00" — us din kis waqt due hoga
  weekday     Int?       // WEEKLY ke liye: 1=Mon ... 7=Sun
  dayOfMonth  Int?       // MONTHLY ke liye: 1-28

  priority    String     @default("NORMAL")
  active      Boolean    @default(true)

  nextFireAt  DateTime?  // agli baar kab task banega
  lastFiredAt DateTime?

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([orgId, active])
  @@index([nextFireAt])
  @@map("checklist_rules")
}