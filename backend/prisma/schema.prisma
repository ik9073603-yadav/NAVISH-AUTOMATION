// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  OWNER
  MANAGER
  EMPLOYEE
}

enum AccountStatus {
  INVITED
  ACTIVE
  DEACTIVATED
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  industry  String?
  timezone  String   @default("Asia/Kolkata")
  gstin     String?
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users       User[]
  departments Department[]

  @@map("organizations")
}

model Department {
  id     String @id @default(uuid())
  orgId  String
  name   String

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  users        User[]

  @@unique([orgId, name])
  @@index([orgId])
  @@map("departments")
}

model User {
  id           String        @id @default(uuid())
  orgId        String
  name         String
  email        String
  phone        String?
  passwordHash String
  role         Role          @default(EMPLOYEE)
  status       AccountStatus @default(ACTIVE)
  managerId    String?
  departmentId String?
  photoUrl     String?
  language     String        @default("en")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  department   Department?  @relation(fields: [departmentId], references: [id])
  manager      User?        @relation("ManagerChain", fields: [managerId], references: [id])
  reports      User[]       @relation("ManagerChain")

  @@unique([orgId, email])
  @@index([orgId])
  @@index([managerId])
  @@map("users")
}

model ActivityLog {
  id        String   @id @default(uuid())
  orgId     String
  actorId   String?
  action    String
  entity    String
  entityId  String?
  meta      Json?
  createdAt DateTime @default(now())

  @@index([orgId, createdAt])
  @@map("activity_logs")
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  STUCK
  DONE
  CANCELLED
}

enum TaskSource {
  DELEGATION
  CHECKLIST
  FMS_STAGE
  INVENTORY_ALERT
}

model Task {
  id          String     @id @default(uuid())
  orgId       String
  title       String
  description String?
  source      TaskSource @default(DELEGATION)
  status      TaskStatus @default(PENDING)
  priority    String     @default("NORMAL")

  assigneeId  String
  createdById String

  dueAt        DateTime?
  completedAt  DateTime?
  stuckReason  String?

  ruleId       String?    // kis checklist rule se bana

  // The engine's brain:
  nextActionAt   DateTime?
  chaseCount     Int       @default(0)
  escalatedAt    DateTime?
  escalatedToId  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, status])
  @@index([nextActionAt])
  @@index([assigneeId, status])
  @@map("tasks")
}

model Notification {
  id        String   @id @default(uuid())
  orgId     String
  userId    String
  type      String
  title     String
  body      String
  taskId    String?
  readAt    DateTime?
  createdAt DateTime @default(now())

  @@index([orgId, userId, createdAt])
  @@map("notifications")
}

enum Recurrence {
  DAILY
  WEEKLY
  MONTHLY
}

model ChecklistRule {
  id          String     @id @default(uuid())
  orgId       String
  title       String
  description String?
  assigneeId  String
  createdById String

  recurrence  Recurrence
  timeOfDay   String     // "09:00" — us din kis waqt due hoga
  weekday     Int?       // WEEKLY ke liye: 1=Mon ... 7=Sun
  dayOfMonth  Int?       // MONTHLY ke liye: 1-28

  priority    String     @default("NORMAL")
  active      Boolean    @default(true)

  nextFireAt  DateTime?  // agli baar kab task banega
  lastFiredAt DateTime?

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([orgId, active])
  @@index([nextFireAt])
  @@map("checklist_rules")
}

enum FieldType {
  TEXT
  NUMBER
  DROPDOWN
  DATE
  PHOTO
  YESNO
}

enum OrderStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

model Flow {
  id          String   @id @default(uuid())
  orgId       String
  name        String
  prefix      String   @default("ORD")   // order number: ORD-001
  itemLabel   String   @default("Item")
  active      Boolean  @default(true)
  orderCount  Int      @default(0)
  createdAt   DateTime @default(now())

  stages StageDef[]
  orders Order[]

  @@index([orgId])
  @@map("flows")
}

model StageDef {
  id            String  @id @default(uuid())
  orgId         String
  flowId        String
  name          String
  sequence      Int                      // 1, 2, 3...
  responsibleId String?                  // kaun karega
  plannedMins   Int?                     // kitna time lagna chahiye

  flow   Flow       @relation(fields: [flowId], references: [id], onDelete: Cascade)
  fields FieldDef[]

  @@index([flowId, sequence])
  @@map("stage_defs")
}

model FieldDef {
  id       String    @id @default(uuid())
  orgId    String
  stageId  String
  label    String
  type     FieldType @default(TEXT)
  required Boolean   @default(false)
  options  String?                     // DROPDOWN ke liye: "A,B,C"
  sequence Int       @default(0)

  stage StageDef @relation(fields: [stageId], references: [id], onDelete: Cascade)

  @@index([stageId])
  @@map("field_defs")
}

model Order {
  id          String      @id @default(uuid())
  orgId       String
  flowId      String
  orderNumber String
  status      OrderStatus @default(ACTIVE)

  currentStageId String?
  startedAt      DateTime  @default(now())
  completedAt    DateTime?

  flow   Flow            @relation(fields: [flowId], references: [id], onDelete: Cascade)
  stages OrderStage[]

  @@unique([orgId, orderNumber])
  @@index([orgId, status])
  @@map("orders")
}

model OrderStage {
  id        String    @id @default(uuid())
  orgId     String
  orderId   String
  stageId   String
  sequence  Int

  taskId       String?     // engine ka task
  enteredAt    DateTime?   // kab yahan aaya
  completedAt  DateTime?
  completedById String?
  data         Json?       // custom fields ka data
  delayMins    Int?        // planned vs actual

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orgId, orderId])
  @@index([stageId])
  @@map("order_stages")
}